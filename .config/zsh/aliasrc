#!/bin/zsh
# --- Eza (Modern ls) ---
# Definiamo i parametri comuni una volta sola per evitare ripetizioni
local eza_common="--icons=auto --group-directories-first"

alias ls="eza ${eza_common}"
alias l="eza ${eza_common} --git-ignore"
alias ll="eza ${eza_common} --all --header --long --git"
alias llm="eza ${eza_common} --all --header --long --sort=modified"
alias la="eza ${eza_common} -lbhHigUmuSa"
alias lx="eza ${eza_common} -lbhHigUmuSa@"
alias lt="eza ${eza_common} --tree"
alias tree="eza ${eza_common} --tree"

# --- Navigazione & File System ---
alias ..="cd .."
alias ...="cd ../.."
alias mkd="mkdir -p"
alias open="xdg-open"

# --- Editing & Strumenti ---
alias edit="emacs -nw"
alias ff="fastfetch"
alias hh="hstr"
alias myip="curl -s https://ifconfig.me; echo" # Più veloce e pulito

# --- Git ---
alias gc="git clone"
alias gcm="git commit -m"
alias gp="git push"     # Abbreviato
alias gl="git pull"     # Abbreviato (l sta per pull/list)
alias gs="git status"   # Fondamentale

# --- Sicurezza & Rimozione ---
# -i (interactive) è utile, ma può essere frustrante. 
# Meglio usare una versione che non chieda conferma per ogni singolo file se sono troppi.
alias rm="rm -v"
alias rmi="rm -iv"
alias rmall="rm -rfv"

# --- Python ---
alias actpy='source "${HOME}/.local/python/bin/activate"'

# --- Pacman (Arch Linux) ---
alias pS='sudo pacman -S'
alias pSy='sudo pacman -Syu'
alias pR='sudo pacman -Rs'
# Pulizia orfani migliorata: evita l'errore se non ci sono pacchetti da rimuovere
alias pclean='sudo pacman -Qtdq | sudo pacman -Rns -'
